{
    "compilerOptions": {
        "lib": ["DOM"],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "paths": {
            "@/*": ["./web/src/*"]
        }
    },
    "include": [
        "web/src/**/*.ts",
        "web/src/**/*.tsx"
    ],
    "exclude": [
        "node_modules"
    ]
}
